# PathShala AI — Environment Variables
# Copy this file to `.env` and fill in your real values before running.
# NEVER commit the real `.env` file to git.

# ─── AWS Bedrock ──────────────────────────────────────────────────────────────
# Region where the Bedrock model is available.
# Claude 3.5 Sonnet v2 is available in us-east-1 and ap-south-1.
AWS_REGION=ap-south-1

# Model ID — do not change for MVP
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# AWS credentials (only needed if NOT using IAM roles / instance profiles)
# If running on EC2/ECS/Render with an attached IAM role, leave these blank.
# Moved to AWS CLI for security.

# ─── Twilio — WhatsApp delivery ───────────────────────────────────────────────
# Account credentials — from https://console.twilio.com
TWILIO_ACCOUNT_SID=AC741fec2b53d13fe84bb7b4dc65c2c9dc
TWILIO_AUTH_TOKEN=fd7268ba19b650a2c0e138f176b6b41d

# Twilio WhatsApp Sandbox sender number (do NOT include "whatsapp:" prefix here)
TWILIO_WHATSAPP_FROM=+14155238886

# Your personal WhatsApp number to receive lessons (must be joined to sandbox)
# Join sandbox: send "join <sandbox-keyword>" to +14155238886 on WhatsApp
TWILIO_WHATSAPP_TO=+916369631956

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development

# Public URL of the deployed backend (update after Render/Railway deploy)
BASE_URL=https://gregoria-transelemental-unneedfully.ngrok-free.dev
